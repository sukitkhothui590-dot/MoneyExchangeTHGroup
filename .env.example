# Copy to Vercel → Project → Settings → Environment Variables (or use `vercel env pull` locally).
# Never commit real keys. SUPABASE_SERVICE_ROLE_KEY is server-only — do not expose to the browser.

# --- Supabase (required for app + API routes that touch the database / storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Server-only: Dashboard admin APIs, article upload, etc. (Production / Preview on Vercel)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Optional behaviour ---
# "false" = use live Supabase data where implemented; omit or "true" = mock/fallback where applicable
# NEXT_PUBLIC_USE_MOCK_DATA=false

# Set to show gray placeholders for heavy images in dev/demo (optional)
# NEXT_PUBLIC_IMAGE_PLACEHOLDERS=true
